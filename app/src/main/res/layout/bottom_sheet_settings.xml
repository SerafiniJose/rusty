<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_card"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Receiver settings"
            android:textColor="@color/ink"
            android:textSize="20sp"
            android:fontFamily="@font/bricolage_bold" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/settingsTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginStart="-12dp"
            android:layout_marginEnd="-12dp"
            android:background="@android:color/transparent"
            app:tabGravity="start"
            app:tabIndicatorColor="@color/accent_fallback"
            app:tabIndicatorFullWidth="false"
            app:tabMode="scrollable"
            app:tabPaddingStart="12dp"
            app:tabPaddingEnd="12dp"
            app:tabRippleColor="@null"
            app:tabSelectedTextColor="@color/accent_fallback"
            app:tabTextColor="@color/muted_dim" />

        <FrameLayout
            android:id="@+id/settingsPanelContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
