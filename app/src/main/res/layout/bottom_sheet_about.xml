<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_card"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- Header: app name + running version, centered. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_bold"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/ink"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/tvAboutVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/hanken_regular"
            android:gravity="center"
            android:text="Version 1.1.0"
            android:textColor="@color/muted_dim"
            android:textSize="14sp" />

        <!-- Update banner: hidden until a check finds a newer release. -->
        <LinearLayout
            android:id="@+id/cardUpdateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_status_pill"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvUpdateBannerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_medium"
                android:text="Update available · 1.2.0"
                android:textColor="@color/ink"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Status line shown while checking, or when up to date / unavailable. -->
        <TextView
            android:id="@+id/tvUpdateStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/hanken_regular"
            android:gravity="center"
            android:text="Checking for updates…"
            android:textColor="@color/muted_dim"
            android:textSize="13sp" />

        <!-- What's new: title + notes, shown only when an update is available. -->
        <TextView
            android:id="@+id/tvWhatsNewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/hanken_medium"
            android:text="What's new"
            android:textColor="@color/ink"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvWhatsNew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/hanken_regular"
            android:lineSpacingMultiplier="1.15"
            android:textColor="@color/muted_dim"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Download: opens the release page in a browser. Shown only when an update exists. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Download on GitHub"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent_fallback"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/surface_border" />

        <!-- Source & releases: always available, opens the repo. -->
        <LinearLayout
            android:id="@+id/rowSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/hanken_medium"
                android:text="Source &amp; releases"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_regular"
                android:text="›"
                android:textColor="@color/muted_dim"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
