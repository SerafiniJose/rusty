<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/haRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <WebView
        android:id="@+id/haWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <TextView
        android:id="@+id/haBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@color/surface_raised"
        android:fontFamily="@font/hanken_regular"
        android:padding="12dp"
        android:textColor="@color/ink"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/haSetup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/hanken_medium"
            android:text="Connect Home Assistant"
            android:textColor="@color/ink"
            android:textSize="22sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/hanken_regular"
            android:text="Enter your dashboard address, e.g. http://homeassistant.local:8123"
            android:textColor="@color/muted_dim"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColorHint="@color/muted_dim"
            app:boxStrokeColor="@color/accent_fallback"
            app:hintTextColor="@color/muted_dim">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHaUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_regular"
                android:hint="Home Assistant URL"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:maxLines="1"
                android:textColor="@color/ink" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvHaError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/hanken_regular"
            android:textColor="@color/dot_red"
            android:textSize="13sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHaConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:foreground="@drawable/bg_tv_focus"
            android:text="Connect"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent_fallback" />
    </LinearLayout>
</FrameLayout>
