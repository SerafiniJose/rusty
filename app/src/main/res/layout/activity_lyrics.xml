<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lyricsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/accent_fallback">

    <LinearLayout
        android:id="@+id/lyricsContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="20dp"
        android:paddingEnd="28dp"
        android:paddingBottom="20dp">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvLyricsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/hanken_semibold"
                android:letterSpacing="0.12"
                android:text="LYRICS"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvLyricsHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:alpha="0.55"
                android:fontFamily="@font/hanken_regular"
                android:text="Tap to close"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </RelativeLayout>

        <!-- Scrolling lyrics -->
        <ScrollView
            android:id="@+id/lyricsScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fadingEdgeLength="64dp"
            android:requiresFadingEdge="vertical"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/lyricsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- Footer: track + provider -->
        <TextView
            android:id="@+id/tvLyricsTrack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/hanken_semibold"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvLyricsProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:fontFamily="@font/hanken_regular"
            android:text=""
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Off-screen probe: Coil decodes the cover here so we can derive a per-track accent. -->
    <ImageView
        android:id="@+id/lyricsCoverProbe"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:importantForAccessibility="no"
        android:visibility="invisible" />

    <!-- Centered status (loading / empty / error) -->
    <TextView
        android:id="@+id/tvLyricsStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/hanken_regular"
        android:gravity="center"
        android:padding="24dp"
        android:text="Loading lyrics…"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:visibility="gone" />
</FrameLayout>
