<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nowPlayingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- Layer 1: drifting mesh (idle background) -->
    <dev.rusty.app.AmbientMeshView
        android:id="@+id/viewAmbientMesh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Layer 2: blurred art wash (playing background) -->
    <ImageView
        android:id="@+id/ivWash"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Layer 3: scrim for text legibility over the wash -->
    <View
        android:id="@+id/viewScrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0"
        android:background="@drawable/bg_scrim_playing"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Layer 4: grain -->
    <dev.rusty.app.GrainView
        android:id="@+id/viewGrain"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Foreground content. The Activity pads THIS (system-bar insets + base margin), so the
         background layers above stay full-bleed to the window edges (no inset border). -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <!-- Top-left identity: dot + name + (active) suffix -->
    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:background="@drawable/bg_status_dot"
            android:contentDescription="Receiver status" />

        <TextView
            android:id="@+id/tvStatusName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:ellipsize="end"
            android:fontFamily="@font/hanken_semibold"
            android:maxLines="1"
            android:text="Salotto"
            android:textColor="@color/ink"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvIdentitySuffix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="· Spotify Connect"
            android:textColor="@color/muted_dim"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Bottom-right: settings + info. Recessive ambient chrome for rare actions, kept clear of
         the top-right corner where the clock parks in the playing state. (id stays `topButtons`
         to avoid churn; nothing references it in code.) -->
    <LinearLayout
        android:id="@+id/topButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.55"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Receiver settings"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings" />

        <ImageButton
            android:id="@+id/btnInfo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Session and receiver health"
            android:scaleType="centerInside"
            android:src="@drawable/ic_info" />
    </LinearLayout>

    <!-- Shared migrating clock: centered in idle, corner in active (driven by BloomController) -->
    <TextView
        android:id="@+id/tvClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bricolage_regular"
        android:includeFontPadding="false"
        android:text="9:41"
        android:textColor="@color/ink"
        android:textSize="120sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42" />

    <!-- Idle group: date + status, centered beneath the clock -->
    <LinearLayout
        android:id="@+id/idleGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvClock">

        <TextView
            android:id="@+id/tvClockDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/hanken_regular"
            android:letterSpacing="0.14"
            android:text="Tuesday · June 8"
            android:textAllCaps="true"
            android:textColor="@color/muted"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvIdleStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/hanken_regular"
            android:text="Ready for Spotify"
            android:textColor="@color/muted_dim"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Playing group (P1 split): cover left, info right -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/albumArtCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivFullAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_album_art_placeholder"
            android:contentDescription="Album art"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvFullAlbumGlyph"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="♫"
            android:textColor="@color/white"
            android:textSize="84sp" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/playingInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/albumArtCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/albumArtCard"
        app:layout_constraintTop_toTopOf="@id/albumArtCard">

        <TextView
            android:id="@+id/tvEyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/hanken_semibold"
            android:letterSpacing="0.18"
            android:text="NOW PLAYING"
            android:textColor="@color/accent_fallback"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvFullTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/bricolage_bold"
            android:maxLines="2"
            android:text="Waiting for Spotify"
            android:textColor="@color/ink"
            android:textSize="40sp" />

        <TextView
            android:id="@+id/tvFullArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/hanken_regular"
            android:maxLines="1"
            android:text="Select this receiver from Spotify"
            android:textColor="@color/muted"
            android:textSize="21sp" />

        <FrameLayout
            android:id="@+id/progressRow"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_progress_track_ambient">

            <View
                android:id="@+id/viewFullProgressFill"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_fill" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFullElapsed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/hanken_regular"
                android:text="0:00"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvFullDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_regular"
                android:text="0:00"
                android:textColor="@color/muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/transportRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous track"
                android:scaleType="centerInside"
                android:src="@drawable/ic_skip_previous" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginStart="22dp"
                android:layout_marginEnd="22dp"
                android:background="@drawable/bg_playpause_button"
                android:contentDescription="Play or pause"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_play" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next track"
                android:scaleType="centerInside"
                android:src="@drawable/ic_skip_next" />
        </LinearLayout>
    </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
