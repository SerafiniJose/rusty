<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- CONNECTION (hidden once signed in). marginBottom carries the gap to the account card; a GONE
         view drops its margins, so hiding this removes the gap automatically (no runtime margin toggle). -->
    <LinearLayout
        android:id="@+id/haConnectionSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.Rusty.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HA Server" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColorHint="@color/muted_dim"
                app:boxStrokeColor="@color/accent_fallback"
                app:hintTextColor="@color/muted_dim">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHaSettingsUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/hanken_regular"
                    android:hint="http://homeassistant.local:8123"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:textColor="@color/ink" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHaClearUrl"
                style="@style/Widget.Rusty.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:foreground="@drawable/bg_tv_focus"
                android:text="Clear" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHaSaveUrl"
                style="@style/Widget.Rusty.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:foreground="@drawable/bg_tv_focus"
                android:text="Save" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/haAccountCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_raised"
        app:cardCornerRadius="@dimen/settings_card_radius"
        app:cardElevation="0dp"
        app:strokeColor="@color/surface_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:id="@+id/haAccountAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:fontFamily="@font/hanken_medium"
                android:textColor="@color/ink"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/haAccountName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/hanken_medium"
                    android:textColor="@color/ink"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/haAccountSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/hanken_regular"
                    android:textColor="@color/muted_dim"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHaAccountAction"
                style="@style/Widget.Rusty.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foreground="@drawable/bg_tv_focus" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/surface_border" />

    <!-- DASHBOARDS & APPS -->
    <TextView
        style="@style/Widget.Rusty.SectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Dashboards &amp; apps" />

    <TextView
        android:id="@+id/tvHaDashboardsHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/hanken_regular"
        android:text="Choose what appears in Rusty."
        android:textColor="@color/muted_dim"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/haDashboardsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHaRefreshDashboards"
        style="@style/Widget.Rusty.Button.Secondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:foreground="@drawable/bg_tv_focus"
        android:text="Refresh" />

    <TextView
        android:id="@+id/tvHaFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/hanken_regular"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
