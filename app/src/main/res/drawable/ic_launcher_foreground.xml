<?xml version="1.0" encoding="utf-8"?>
<!-- Librespot receiver launcher foreground (adaptive).
     The full record + broadcast-wave composition, scaled and centered into the
     adaptive-icon safe zone (~66-72dp) so no launcher mask clips the art. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="67.75"
        android:pivotY="51"
        android:scaleX="0.64"
        android:scaleY="0.64"
        android:translateX="-13.75"
        android:translateY="3">

        <!-- Green receiver/audio waves. -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#1ED760"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:pathData="M71,41 C78,47 78,61 71,67" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#1ED760"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:pathData="M80,31 C94,43 94,65 80,77" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#1ED760"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:pathData="M88,22 C108,40 108,68 88,86" />

        <!-- Orange connection accent: rotated 180 and lifted above the record. -->
        <group
            android:rotation="180"
            android:pivotX="84"
            android:pivotY="22"
            android:translateX="-30"
            android:translateY="-6">
            <path
                android:fillColor="#00000000"
                android:strokeColor="#FF9F1C"
                android:strokeWidth="3.5"
                android:strokeLineCap="round"
                android:pathData="M75,21 C80,16 88,16 93,21" />
            <path
                android:fillColor="#00000000"
                android:strokeColor="#FF9F1C"
                android:strokeWidth="3.5"
                android:strokeLineCap="round"
                android:pathData="M80,27 C83,24 87,24 90,27" />
        </group>

        <!-- Central record / target symbol. -->
        <path
            android:fillColor="#0A0C0F"
            android:pathData="M54,25 A29,29 0,1 0,54.1 25 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M54,32 A22,22 0,1 0,54.1 32 Z" />
        <path
            android:fillColor="#111418"
            android:pathData="M54,39 A15,15 0,1 0,54.1 39 Z" />
        <path
            android:fillColor="#1ED760"
            android:pathData="M54,46 A8,8 0,1 0,54.1 46 Z" />
        <path
            android:fillColor="#74F29A"
            android:pathData="M50,49 A2.3,2.3 0,1 0,50.1 49 Z" />
    </group>
</vector>
