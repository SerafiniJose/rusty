<?xml version="1.0" encoding="utf-8"?>
<!-- D-pad focus ring for the settings switches: stroke-only, fully rounded into a pill so it
     outlines the switch rather than boxing it in a loose rectangle. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <stroke
                android:width="2dp"
                android:color="@color/accent_fallback" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
