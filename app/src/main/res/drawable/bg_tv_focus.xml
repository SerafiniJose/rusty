<?xml version="1.0" encoding="utf-8"?>
<!-- D-pad focus indicator for Android TV (NVIDIA Shield). Applied as android:foreground on
     interactive controls so the existing ripple background is preserved. Draws a brand-green
     ring only while the view holds D-pad focus; invisible to touch users on phones/tablets. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <stroke
                android:width="2dp"
                android:color="@color/accent_fallback" />
            <solid android:color="#221ED760" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
