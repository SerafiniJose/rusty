<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome (Android 13+ themed icon) variant: single-tint silhouette of the
     record + broadcast waves. The system tints this; only alpha matters. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="67.75"
        android:pivotY="51"
        android:scaleX="0.64"
        android:scaleY="0.64"
        android:translateX="-13.75"
        android:translateY="3">

        <!-- Broadcast waves. -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:pathData="M71,41 C78,47 78,61 71,67" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:pathData="M80,31 C94,43 94,65 80,77" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:pathData="M88,22 C108,40 108,68 88,86" />

        <!-- Connection accent (mono): rotated 180 and lifted above the record. -->
        <group
            android:rotation="180"
            android:pivotX="84"
            android:pivotY="22"
            android:translateX="-30"
            android:translateY="-6">
            <path
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3.5"
                android:strokeLineCap="round"
                android:pathData="M75,21 C80,16 88,16 93,21" />
            <path
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="3.5"
                android:strokeLineCap="round"
                android:pathData="M80,27 C83,24 87,24 90,27" />
        </group>

        <!-- Record as a ring (outer disc minus inner hole) plus center dot. -->
        <path
            android:fillColor="#FFFFFF"
            android:fillType="evenOdd"
            android:pathData="M54,25 A29,29 0,1 0,54.1 25 Z M54,40 A14,14 0,1 1,53.9 40 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M54,47 A7,7 0,1 0,54.1 47 Z" />
    </group>
</vector>
